# Copy to .env and adjust (never commit .env with secrets).

# Image tag for local / CI builds
# AEGIS_IMAGE_TAG=local

# NATS (cluster entrypoint — must match docker-compose service name)
# AEGIS_NATS_URL=nats://nats-1:4222

# DataBus → Orchestrator → Memory (container hostnames on aegis-net)
# AEGIS_ORCHESTRATOR_URL=http://orchestrator-stub:8091
# AEGIS_MEMORY_URL=http://memory-stub:8090/v1/memory

# TLS to NATS (mount CA in container)
# AEGIS_NATS_TLS_CA=/path/in/container/ca.pem
# AEGIS_NATS_TLS_CERT=...
# AEGIS_NATS_TLS_KEY=...

# OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
