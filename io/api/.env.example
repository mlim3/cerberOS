# Memory service integration (optional — IO API uses in-memory fallback when unset)
# When MEMORY_API_BASE is set, log entries are persisted to the Memory service.
# When unset, the IO API runs in demo mode with in-memory log storage.

# Base URL of the Memory HTTP service (e.g. http://localhost:8080)
MEMORY_API_BASE=

# API key for the Memory service's internal API
MEMORY_API_KEY=

# Memory Vault URL (proxied for credential submission)
# Defaults to http://localhost:8080/api/v1/vault
MEMORY_VAULT_URL=

# API key for the Memory Vault
MEMORY_VAULT_API_KEY=

# Voice / STT (faster-whisper)
WHISPER_MODEL=base.en          # Model size: tiny, base, small, medium, large
WHISPER_MODEL_DIR=/app/whisper-models
WHISPER_DEVICE=cpu             # cpu or cuda (GPU support if CUDA available)

# Cloud STT fallback (used when local faster-whisper fails or STT_PROVIDER=cloud)
STT_PROVIDER=local             # local, cloud (skip local entirely), or openai
OPENAI_API_KEY=                # Required for cloud fallback
STT_API_URL=https://api.openai.com/v1/audio/transcriptions  # Override for proxy/custom endpoint
STT_MODEL=whisper-1            # Model name for cloud STT API
