# cerberOS CLI Surface — Environment Variables

# IO API server URL
CLI_API_BASE=http://localhost:3001

# Orchestrator URL
ORCHESTRATOR_URL=http://localhost:9000

# NATS URL (optional)
# NATS_URL=nats://localhost:4222

# User UUID for vault namespace
# CLI_USER_ID=00000000-0000-0000-0000-000000000001

# Surface identifier (auto-generated by default)
# CLI_SURFACE_ID=cli-myhost-1234567890

# Session persistence file
# SESSION_FILE=~/.cerberos/cli-session.json

# Disable colors (1 = disabled)
# CLI_NO_COLOR=1

# Disable spinners (1 = disabled)
# CLI_NO_SPINNER=1

# SSE poll interval in ms
# CLI_POLL_INTERVAL=2000

# Memory API base (optional)
# MEMORY_API_BASE=http://localhost:8080
