# =============================================================================
# cerberOS root stack — environment variables
# =============================================================================
# Copy this file to .env and fill in the values before running:
#   docker compose up --build
#
# NEVER commit .env with real secrets.
# =============================================================================

# -- Postgres (shared by memory-api and openbao) --
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=memory_db

# -- Memory API --
# Must be exactly 32 ASCII characters (raw bytes, not hex-encoded).
# Generate with: openssl rand -base64 24 | head -c 32
VAULT_MASTER_KEY=
# Any strong random string — used to authenticate internal requests to the memory vault API.
# docker-compose also passes this to io as MEMORY_API_KEY so /api/user-crons can proxy to memory-api.
INTERNAL_VAULT_API_KEY=

# -- IO (when running bun against dockerized memory-api on localhost:8081) --
# MEMORY_API_BASE=http://127.0.0.1:8081

# -- OpenBao / Vault engine --
# Populated by ./bootstrap.sh after OpenBao init + unseal.
# Leave blank on first run; set after bootstrapping.
BAO_TOKEN=

# -- Agents (profile: agents)  --
# Required only when running: docker compose --profile agents up
ANTHROPIC_API_KEY=

# -- Web search (Tavily AI Search API) --
# Required for the web_search skill. Get a key at https://tavily.com
# bootstrap.sh seeds this into OpenBao automatically when set.
TAVILY_API_KEY=

# -- OpenAI (memory embedder + optional GPT skills) --
# Optional. Manager can also configure later via the Admin UI / `cerberos admin set-llm-key`.
OPENAI_API_KEY=

# -- Google Workspace (Gmail SMTP via App Password — no OAuth) --
# Powers the gmail_send and calendar_create_event skills (google_workspace domain).
# Use a DEDICATED demo Gmail account, not a personal one.
#
# Setup:
#   1. Create / log into the demo Google account
#   2. Enable 2-Step Verification at https://myaccount.google.com/security
#   3. Generate an App Password at https://myaccount.google.com/apppasswords
#      (Google displays it as "xxxx xxxx xxxx xxxx" — spaces are fine here)
#   4. Paste the email and password below, OR configure later in the Admin UI's
#      "Gmail Demo Account" section / via `cerberos admin set-gmail`.
#
# IMPORTANT: wrap the app password in DOUBLE QUOTES — the spaces in
# `xxxx xxxx xxxx xxxx` will otherwise be parsed as separate shell tokens by
# bootstrap.sh when it sources this file (you'll see "command not found").
#
# bootstrap.sh seeds these into OpenBao as a single `gmail_app_password` key.
GMAIL_DEMO_EMAIL=
GMAIL_DEMO_APP_PASSWORD=""
