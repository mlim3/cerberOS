# =============================================================================
# cerberOS root stack — environment variables
# =============================================================================
# Copy this file to .env and fill in the values before running:
#   docker compose up --build
#
# NEVER commit .env with real secrets.
# =============================================================================

# -- Postgres (shared by memory-api and openbao) --
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=memory_db

# -- Memory API --
# Must be exactly 32 ASCII characters (raw bytes, not hex-encoded).
# Generate with: openssl rand -base64 24 | head -c 32
VAULT_MASTER_KEY=
# Any strong random string — used to authenticate internal requests to the memory vault API
INTERNAL_VAULT_API_KEY=

# -- OpenBao / Vault engine --
# Populated by ./bootstrap.sh after OpenBao init + unseal.
# Leave blank on first run; set after bootstrapping.
BAO_TOKEN=

# -- Agents (profile: agents) --
# Required only when running: docker compose --profile agents up
ANTHROPIC_API_KEY=
